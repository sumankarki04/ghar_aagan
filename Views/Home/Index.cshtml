@model HomeViewModel
@{
    ViewData["Title"] = "Trusted Home Services in Nepal";
}

@* ---------- 1. Hero: search-first (marketplace pattern) ---------- *@
<section class="ga-hero">
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="ga-hero-chip"><i class="bi bi-patch-check-fill"></i> Admin-verified providers</span>
        <span class="ga-hero-chip"><i class="bi bi-cash-coin"></i> Transparent hourly rates</span>
        <span class="ga-hero-chip"><i class="bi bi-star-fill"></i> Real reviews</span>
    </div>

    <h1 class="fw-bold mb-3">
        Your home's <span class="accent">aagan</span>,<br />our trusted hands.
    </h1>
    <p class="lead mb-4">
        Book verified plumbers, electricians, cleaners, carpenters and painters
        near you — with up-front pricing and review-based trust.
    </p>

    <form class="ga-search-card d-flex flex-column flex-sm-row align-items-stretch gap-1"
          method="get" asp-controller="Providers" asp-action="Browse" role="search" aria-label="Find a service">
        <div class="flex-fill d-flex align-items-center px-2">
            <i class="bi bi-tools me-2" style="color: var(--ga-terra-600);" aria-hidden="true"></i>
            <select class="form-select" name="categoryId" required aria-label="Service category">
                <option value="" selected disabled>What do you need?</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="ga-search-divider d-none d-sm-block" aria-hidden="true"></div>
        <div class="flex-fill d-flex align-items-center px-2">
            <i class="bi bi-geo-alt me-2" style="color: var(--ga-terra-600);" aria-hidden="true"></i>
            <input type="text" class="form-control" name="location" placeholder="Your area (e.g. Baneshwor)"
                   aria-label="Your location" />
        </div>
        <button type="submit" class="btn btn-terracotta px-4 py-2 flex-shrink-0">
            <i class="bi bi-search me-1" aria-hidden="true"></i>Search
        </button>
    </form>
</section>

@* ---------- 2. Trust stats strip ---------- *@
<div class="ga-stats-strip">
    <div class="cell">
        <div class="num">@Model.VerifiedProviderCount</div>
        <div class="lbl">Verified Providers</div>
    </div>
    <div class="cell">
        <div class="num">@Model.CompletedJobCount+</div>
        <div class="lbl">Jobs Completed</div>
    </div>
    <div class="cell">
        <div class="num">@Model.AverageRating.ToString("0.0") <i class="bi bi-star-fill ga-stars" style="font-size:1.1rem" aria-hidden="true"></i></div>
        <div class="lbl">Average Rating</div>
    </div>
</div>

@* ---------- 3. Categories ---------- *@
<section id="services" class="mb-5">
    <h2 class="section-title">Browse Services</h2>
    <p class="section-sub">Six essential home services, one trusted courtyard.</p>

    <div class="row g-3">
        @foreach (var category in Model.Categories)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <a class="text-decoration-none d-block h-100" asp-controller="Providers" asp-action="Browse" asp-route-categoryId="@category.Id"
                   aria-label="Browse @category.Name providers">
                    <div class="card ga-category-card">
                        <div class="card-body d-flex gap-3">
                            <div class="ga-category-icon flex-shrink-0" aria-hidden="true">
                                <i class="bi @category.IconClass"></i>
                            </div>
                            <div class="min-w-0">
                                <h3 class="card-title h6 mb-1">@category.Name</h3>
                                <p class="card-text text-muted small mb-2">@category.Description</p>
                                <span class="small fw-semibold" style="color: var(--ga-terra-600);">
                                    @category.Providers.Count provider@(category.Providers.Count == 1 ? "" : "s")
                                    <i class="bi bi-arrow-right ms-1" aria-hidden="true"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

@* ---------- 4. Featured providers (social proof) ---------- *@
@if (Model.FeaturedProviders.Any())
{
    <section class="mb-5">
        <h2 class="section-title">Top-Rated Providers</h2>
        <p class="section-sub">Highest-rated verified professionals on Ghar Aagan right now.</p>

        <div class="row g-3">
            @foreach (var p in Model.FeaturedProviders)
            {
                <div class="col-12 col-md-4">
                    <div class="card ga-provider-card h-100">
                        <div class="card-body">
                            <div class="d-flex gap-3 mb-2">
                                <div class="ga-avatar" aria-hidden="true">@string.Concat(p.User.FullName.Split(' ').Take(2).Select(n => n[0]))</div>
                                <div class="min-w-0">
                                    <h3 class="h6 mb-0 text-truncate">@p.User.FullName</h3>
                                    <span class="small text-muted">@p.ServiceCategory.Name · @p.Location.Split('-')[0].Trim()</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="ga-stars" aria-label="@p.AverageRating.ToString("0.0") out of 5 stars">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <i class="bi @(s <= Math.Round(p.AverageRating) ? "bi-star-fill" : "bi-star")" aria-hidden="true"></i>
                                    }
                                </span>
                                <span class="badge badge-verified"><i class="bi bi-patch-check-fill me-1" aria-hidden="true"></i>Verified</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="ga-price-chip">NPR @p.HourlyRate.ToString("0")/hr</span>
                                <a class="btn btn-sm btn-green" asp-controller="Providers" asp-action="Details" asp-route-id="@p.Id">
                                    View Profile
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

@* ---------- 5. Trust & safety ---------- *@
<section class="mb-5">
    <h2 class="section-title">Why households trust Ghar Aagan</h2>
    <p class="section-sub">Built to fix the informal, word-of-mouth way Nepal finds home services today.</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="ga-trust-tile">
                <div class="icon" aria-hidden="true"><i class="bi bi-patch-check-fill"></i></div>
                <h3 class="h6">Identity-Verified Providers</h3>
                <p class="text-muted mb-0">Every provider is reviewed and approved by our admin team before they can take a single booking.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ga-trust-tile">
                <div class="icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></div>
                <h3 class="h6">No Surprise Pricing</h3>
                <p class="text-muted mb-0">Hourly rates are public. You see the estimated price before you confirm — not after the job.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ga-trust-tile">
                <div class="icon" aria-hidden="true"><i class="bi bi-star-fill"></i></div>
                <h3 class="h6">Reviews You Can Rely On</h3>
                <p class="text-muted mb-0">Only customers with completed bookings can review — ratings reflect real jobs, not bots.</p>
            </div>
        </div>
    </div>
</section>

@* ---------- 6. Become-a-provider CTA band ---------- *@
<section class="ga-cta-band d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h2 class="h3 mb-1">Are you a skilled professional?</h2>
        <p class="mb-0">Join Ghar Aagan, get verified, and grow your business with steady local bookings.</p>
    </div>
    <a class="btn btn-lg flex-shrink-0" asp-controller="Account" asp-action="Register">
        Become a Provider <i class="bi bi-arrow-right ms-1" aria-hidden="true"></i>
    </a>
</section>
