@using GharAagan.Data
@using Microsoft.EntityFrameworkCore
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext Db

<ul class="navbar-nav ms-auto align-items-lg-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        var userId = user?.Id ?? "";
        var isCustomerOrProvider = User.IsInRole("Customer") || User.IsInRole("Provider");

        int unread = 0;
        if (isCustomerOrProvider && userId != "")
        {
            // Unread messages addressed to me across my bookings.
            unread = await Db.Messages
                .AsNoTracking()
                .CountAsync(m => !m.IsRead && m.SenderId != userId &&
                    (m.Booking.CustomerId == userId || m.Booking.ProviderProfile.UserId == userId));
        }

        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Panel</a></li>
        }
        @if (User.IsInRole("Provider"))
        {
            <li class="nav-item"><a class="nav-link" asp-controller="Provider" asp-action="Dashboard">Dashboard</a></li>
        }
        @if (User.IsInRole("Customer"))
        {
            <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="MyBookings">My Bookings</a></li>
        }
        @if (isCustomerOrProvider)
        {
            <li class="nav-item">
                <a class="nav-link position-relative" asp-controller="Messages" asp-action="Inbox"
                   aria-label="Messages@(unread > 0 ? $", {unread} unread" : "")">
                    <i class="bi bi-chat-dots" aria-hidden="true"></i>
                    <span class="d-lg-none ms-1">Messages</span>
                    @if (unread > 0)
                    {
                        <span class="ga-unread-badge">@(unread > 9 ? "9+" : unread.ToString())</span>
                    }
                </a>
            </li>
        }
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
                <span class="ga-avatar" style="width:1.9rem;height:1.9rem;font-size:.75rem;">
                    @string.Concat((user?.FullName ?? "U").Split(' ').Take(2).Select(n => n[0]))
                </span>
                <span class="d-none d-lg-inline">@(user?.FullName.Split(' ')[0])</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><h6 class="dropdown-header">@user?.FullName</h6></li>
                <li><a class="dropdown-item" asp-controller="Account" asp-action="Manage">
                    <i class="bi bi-person me-2" aria-hidden="true"></i>My Profile</a></li>
                @if (User.IsInRole("Provider"))
                {
                    <li><a class="dropdown-item" asp-controller="Provider" asp-action="EditProfile">
                        <i class="bi bi-briefcase me-2" aria-hidden="true"></i>Provider Profile</a></li>
                    <li><a class="dropdown-item" asp-controller="Provider" asp-action="Availability">
                        <i class="bi bi-clock me-2" aria-hidden="true"></i>Availability</a></li>
                }
                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                    <i class="bi bi-key me-2" aria-hidden="true"></i>Change Password</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right me-2" aria-hidden="true"></i>Logout
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
        <li class="nav-item">
            <a class="btn btn-marigold btn-sm ms-lg-2" asp-controller="Account" asp-action="Register">Sign Up</a>
        </li>
    }
</ul>
