@model List<ConversationSummary>
@{
    ViewData["Title"] = "Messages";
}

<h1 class="h2 mb-1">Messages</h1>
<p class="section-sub">Chat with your @(User.IsInRole("Provider") ? "customers" : "providers") about each booking.</p>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-chat-dots" style="font-size: 3rem; color: var(--ga-ink-400);" aria-hidden="true"></i>
        <p class="text-muted mt-3">No conversations yet. Conversations open automatically with every booking.</p>
    </div>
}
else
{
    <div class="list-group ga-inbox">
        @foreach (var conversation in Model)
        {
            <a asp-action="Thread" asp-route-id="@conversation.BookingId"
               class="list-group-item list-group-item-action d-flex gap-3 align-items-center py-3">
                <div class="ga-avatar" aria-hidden="true">@string.Concat(conversation.OtherPartyName.Split(' ').Take(2).Select(n => n[0]))</div>
                <div class="flex-fill min-w-0">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <strong class="text-truncate">@conversation.OtherPartyName</strong>
                        <span class="small text-muted flex-shrink-0">
                            @(conversation.LastMessageAt?.ToLocalTime().ToString("dd MMM, HH:mm") ?? "")
                        </span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <span class="small text-muted text-truncate">
                            @(conversation.LastMessage ?? "No messages yet — say namaste!")
                        </span>
                        @if (conversation.UnreadCount > 0)
                        {
                            <span class="badge rounded-pill" style="background: var(--ga-terra-500);">@conversation.UnreadCount</span>
                        }
                    </div>
                    <div class="small mt-1">
                        <span class="badge status-@conversation.BookingStatus">@conversation.BookingStatus</span>
                        <span class="text-muted ms-1">@conversation.ServiceName · @conversation.ScheduledDateTime.ToString("dd MMM yyyy")</span>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted" aria-hidden="true"></i>
            </a>
        }
    </div>
}
