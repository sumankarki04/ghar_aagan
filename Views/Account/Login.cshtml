@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="ga-auth-card">
    <div class="card">
        <div class="card-header"><i class="bi bi-box-arrow-in-right me-2"></i>Welcome back</div>
        <div class="card-body">
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-terracotta w-100">Log In</button>
            </form>
            <p class="text-center mt-3 mb-0 small">
                New to Ghar Aagan? <a asp-action="Register">Create an account</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
